<div class="list-group-item d-flex justify-content-between align-items-start">
  <div class="ms-2 me-auto">
    <div class="fw-bold">{{question}}</div>
    <span class="text-muted">Tu respuesta: {{yourAnswer}}</span>
    {{#unless isCorrect}}
      <div class="text-danger">Respuesta correcta: {{correctAnswer}}</div>
    {{/unless}}
  </div>
  {{#if isCorrect}}
    <span class="badge bg-success rounded-pill" aria-label="Respuesta correcta">
      <i class="bi bi-check-lg"></i>
    </span>
  {{else}}
    <span class="badge bg-danger rounded-pill" aria-label="Respuesta incorrecta">
      <i class="bi bi-x-lg"></i>
    </span>
  {{/if}}
</div>
