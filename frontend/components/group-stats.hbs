<div class="card shadow-sm border-0 mb-3">
  <div class="card-body">
    <div class="row text-center">
      <div class="col-12 col-md-4 mb-2">
        <p class="mb-0">
          <span class="fw-bold">Promedio del grupo:</span><br>
          <span>{{average}}%</span>
        </p>
      </div>
      <div class="col-12 col-md-4 mb-2">
        <p class="mb-0 text-primary">
          <span class="fw-bold">Tu posición:</span><br>
          <span>{{position}} de {{totalStudents}}</span>
        </p>
      </div>
      <div class="col-12 col-md-4 mb-2">
        <p class="mb-0 text-success">
          <span class="fw-bold">Puntuación más alta:</span><br>
          <span>{{highestScore}}%</span>
        </p>
      </div>
    </div>
  </div>
</div>
