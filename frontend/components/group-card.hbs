<article class="card border-0 shadow-sm h-100">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div
                class="rounded d-flex align-items-center justify-content-center"
                style="width: 48px; height: 48px; background-color: rgba(0, 201, 80, 0.12);"
                aria-hidden="true"
            >
                <i
                    class="bi bi-people"
                    style="color: var(--color-success); font-size: 1.25rem;"
                ></i>
            </div>

            <div class="dropdown">
                <button
                    class="btn btn-sm btn-link text-muted text-decoration-none"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-label="Opciones del grupo {{name}}"
                >
                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                </button>

		<ul class="dropdown-menu dropdown-menu-end">
		    <li>
                        <a
                            class="dropdown-item"
                            href="/groups/{{code}}"
                        >
                            Ver grupo
                        </a>
                    </li>

		   {{#if (or (eq @root.user.role 'teacher') (eq @root.user.role 'admin'))}} 
                    <li>
                        <a
                            class="dropdown-item"
                            href="/groups/{{code}}/edit"
                        >
                            Editar grupo
                        </a>
		    </li>

		    <li>
<button
    type="button"
    class="dropdown-item text-danger"
    onclick="deleteGroup('{{code}}')"
>
    Borrar grupo
</button>
		    </li>
	            {{/if}}


                </ul>
            </div>
        </div>

        <h2 class="h5 fw-semibold mb-2">
            {{name}}
        </h2>

        <span class="badge text-bg-light align-self-start mb-4">
            {{code}}
        </span>

        <div class="border-top pt-3 mt-auto">
            <div class="d-flex justify-content-between align-items-center small mb-2">
                <span class="text-muted">
                    <i class="bi bi-people me-1" aria-hidden="true"></i>
                    {{membersCount}} miembros
                </span>

                <span class="text-muted">
                    <i class="bi bi-file-earmark-text me-1" aria-hidden="true"></i>
                    {{quizzesCount}} cuestionarios
                </span>
            </div>

            <p class="text-muted small mb-0">
                Creado: {{created_at}}
            </p>
        </div>
    </div>

<script>
async function deleteGroup(code) {

    const ok = confirm(
        '¿Seguro que deseas borrar este grupo?'
    );

    if (!ok) {
        return;
    }

    try {

        const res = await fetch(
            `/api/groups/${code}`,
            {
                method: 'DELETE'
            }
        );

        if (res.ok) {

            window.location.href =
                '/groups';

            return;
        }

        alert(
            'No se pudo borrar el grupo'
        );

    } catch (err) {

        console.error(err);

        alert(
            'Error eliminando grupo'
        );
    }
}
</script>

</article>
