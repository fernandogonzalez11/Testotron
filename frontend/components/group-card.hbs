<article class="card border-0 shadow-sm h-100">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div
                class="rounded d-flex align-items-center justify-content-center"
                style="width: 48px; height: 48px; background-color: rgba(0, 201, 80, 0.12);"
                aria-hidden="true"
            >
                <i
                    class="bi bi-people"
                    style="color: var(--color-success); font-size: 1.25rem;"
                ></i>
            </div>

            <div class="dropdown">
                <button
                    class="btn btn-sm btn-link text-muted text-decoration-none"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-label="Opciones del grupo {{name}}"
                >
                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                </button>

                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <a
                            class="dropdown-item"
                            href="/groups/{{id}}"
                        >
                            Ver grupo
                        </a>
                    </li>

                    <li>
                        <a
                            class="dropdown-item"
                            href="/groups/{{id}}/edit"
                        >
                            Editar grupo
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <h2 class="h5 fw-semibold mb-2">
            {{name}}
        </h2>

        <span class="badge text-bg-light align-self-start mb-4">
            {{code}}
        </span>

        <div class="border-top pt-3 mt-auto">
            <div class="d-flex justify-content-between align-items-center small mb-2">
                <span class="text-muted">
                    <i class="bi bi-people me-1" aria-hidden="true"></i>
                    {{students}} miembros
                </span>

                <span class="text-muted">
                    <i class="bi bi-file-earmark-text me-1" aria-hidden="true"></i>
                    {{quizzes}} cuestionarios
                </span>
            </div>

            <p class="text-muted small mb-0">
                Creado: {{createdAt}}
            </p>
        </div>
    </div>
</article>