<div class="col-12 col-md-6">
  <article class="card border-0 shadow-sm h-100">
    <div class="card-body d-flex flex-column justify-content-between">
      <header class="mb-3">
        <h2 class="h5 fw-bold mb-1">{{title}}</h2>
        <p class="text-muted small mb-0">{{group}}</p>
      </header>
      <ul class="list-unstyled mb-3">
        <li><strong>Preguntas:</strong> {{questions}}</li>
        <li><strong>Tiempo límite:</strong> {{timeLimit}} min</li>
        <li><strong>Fecha límite:</strong> {{dueDate}}</li>
        <li><strong>Intentos:</strong> {{attempts}}</li>
        {{#if score}}
          <li><strong>Puntuación obtenida:</strong> {{score}}</li>
        {{/if}}
      </ul>
      <div class="d-flex gap-2">
        {{#if score}}
          <!-- Ya se hizo -->
          <button class="btn btn-primary flex-fill">
            <i class="bi bi-eye me-1"></i> Ver resultados
          </button>
          {{#if canRetry}}
            <button class="btn btn-primary flex-fill">
              <i class="bi bi-arrow-repeat me-1"></i> Reintentar
            </button>
          {{/if}}
        {{else}}
          <!-- Pendiente -->
          <button class="btn btn-primary flex-fill">
            <i class="bi bi-play-fill me-1"></i> Comenzar cuestionario
          </button>
        {{/if}}
      </div>
    </div>
  </article>
</div>
