<table class="table table-striped table-hover">
  <thead>
    <tr>
      {{#each headers}}
        <th>{{this}}</th>
      {{/each}}
      {{#if actions}}
        <th>Acciones</th>
      {{/if}}
    </tr>
  </thead>
  <tbody>
    {{#each rows}}
      <tr>
        {{#each ../headers}}
          <td>{{lookup ../this this}}</td>
        {{/each}}
        {{#if ../actions}}
          <td>
            {{#each ../actions}}
              <a href="{{url}}" class="btn btn-sm btn-{{color}}" aria-label="{{label}}">
                <i class="bi {{icon}}"></i> {{label}}
              </a>
            {{/each}}
          </td>
        {{/if}}
      </tr>
    {{/each}}
  </tbody>
</table>
