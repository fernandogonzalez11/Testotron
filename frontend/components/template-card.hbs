<article class="card border-0 shadow-sm h-100">
  <div class="card-body d-flex flex-column">
    <div class="d-flex align-items-start justify-content-between mb-3">
      <div
        class="rounded d-flex align-items-center justify-content-center"
        style="width: 40px; height: 40px; background-color: rgba(43, 127, 255, 0.12);"
        aria-hidden="true"
      >
        <i
          class="bi bi-file-earmark-text"
          style="color: var(--color-primary);"
        ></i>
      </div>

      <span class="badge rounded-pill text-bg-light">
        {{category}}
      </span>
    </div>

    <h2 class="h6 fw-semibold mb-2">
      {{title}}
    </h2>

    <p class="text-muted small mb-4">
      {{description}}
    </p>

    <div class="d-flex justify-content-between small text-muted mb-4">
      <span>
        <strong>Preguntas:</strong>
        {{questions}}
      </span>

      <span>
        <strong>Usos:</strong>
        {{uses}}
      </span>
    </div>

    <div class="d-flex gap-2 mt-auto">
      <form
        action="/teacher/templates/{{id}}/use"
        method="POST"
        class="flex-grow-1"
      >
        <button
          type="submit"
          class="btn text-white w-100"
          style="background-color: var(--color-primary);"
          aria-label="Usar plantilla {{title}}"
        >
          <i class="bi bi-copy me-1" aria-hidden="true"></i>
          Usar plantilla
        </button>
      </form>

      <a
        href="/teacher/templates/{{id}}"
        class="btn btn-outline-secondary"
        aria-label="Ver detalles de {{title}}"
      >
        <i class="bi bi-eye" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</article>