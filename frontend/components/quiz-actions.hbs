<div
  class="d-flex flex-wrap justify-content-end gap-1"
  role="group"
  aria-label="Acciones para el cuestionario: {{this.title}}"
>

  <a
    href="/teacher/quizzes/edit/{{this.code}}"
    class="btn btn-sm btn-outline-primary"
    title="Editar"
  >
    <i class="bi bi-pencil"></i>
  </a>

  <a
    href="/teacher/quizzes/view/{{this.code}}"
    class="btn btn-sm btn-outline-secondary"
    title="Ver"
  >
    <i class="bi bi-eye"></i>
  </a>

  <button
    type="button"
    class="btn btn-sm btn-outline-secondary duplicate-quiz-btn"
    data-code="{{this.code}}"
    title="Duplicar"
  >
    <i class="bi bi-files"></i>
  </button>

  <button
    type="button"
    class="btn btn-sm btn-outline-secondary share-quiz-btn"
    data-code="{{this.code}}"
    title="Compartir"
  >
    <i class="bi bi-share"></i>
  </button>

  <button
    type="button"
    class="btn btn-sm btn-outline-danger delete-quiz-btn"
    data-code="{{this.code}}"
    title="Eliminar"
  >
    <i class="bi bi-trash"></i>
  </button>

</div>
