<!-- Cabecera de la Página -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 fw-bold text-dark mb-1">Mis cuestionarios</h1>
        <p class="text-muted mb-0">Gestiona y organiza todos tus cuestionarios</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary">Importar cuestionario</button>
        <button class="btn btn-outline-secondary">Banco de preguntas</button>
        <button class="btn btn-outline-secondary">Plantillas</button>
        <!-- Botón de Creación (Verde var(--color-success)) -->
        <a href="/teacher/quizzes/create" class="btn btn-success d-flex align-items-center">
            <i class="bi bi-plus-lg me-2" aria-hidden="true"></i> Crear cuestionario
        </a>
    </div>
</div>

<!-- Barra de búsqueda -->
<div class="row mb-4">
    <div class="col-md-8">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0" id="search-icon">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="search" class="form-control border-start-0" placeholder="Buscar cuestionarios por nombre..." aria-label="Buscar cuestionarios" aria-describedby="search-icon">
        </div>
    </div>
    <div class="col-md-4 text-end">
        <select class="form-select w-auto d-inline-block" aria-label="Filtrar por estado">
            <option selected>Todos los estados</option>
            <option value="active">Activo</option>
            <option value="draft">Borrador</option>
        </select>
    </div>
</div>

<!-- Estadísticas (Accesibilidad: role="region") -->
<section class="row mb-4 g-3" role="region" aria-label="Estadísticas de cuestionarios">
    <div class="col-md-3">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body p-4">
                <p class="text-muted small mb-1">Total</p>
                <p class="h1 fw-bold mb-0">{{stats.total}}</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body p-4 border-start border-4 border-success rounded">
                <p class="text-muted small mb-1">Activos</p>
                <p class="h1 fw-bold text-success mb-0">{{stats.active}}</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body p-4 border-start border-4 border-warning rounded">
                <p class="text-muted small mb-1">Borradores</p>
                <p class="h1 fw-bold text-warning mb-0">{{stats.drafts}}</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body p-4">
                <p class="text-muted small mb-1">Respuestas totales</p>
                <p class="h1 fw-bold text-primary mb-0">{{stats.totalResponses}}</p>
            </div>
        </div>
    </div>
</section>

<!-- Tabla de Cuestionarios -->
<div class="card shadow-sm border-0 mb-5">
    <div class="table-responsive">
        <table class="table table-hover table-striped align-middle mb-0" aria-label="Lista de cuestionarios">
            <thead class="table-light text-uppercase small text-muted">
                <tr>
                    <th scope="col" class="ps-4">Cuestionario</th>
                    <th scope="col">Grupo</th>
                    <th scope="col">Preguntas</th>
                    <th scope="col">Respuestas</th>
                    <th scope="col">Estado</th>
                    <th scope="col">Código</th>
                    <th scope="col" class="text-end pe-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {{#each quizzes}}
                <tr>
                    <td class="ps-4 py-3">
                        <p class="fw-bold mb-0 text-capitalize">{{this.title}}</p>
                        <p class="small text-muted mb-0">Creado: {{this.createdAt}}</p>
                    </td>
                    <td class="text-capitalize">{{this.group}}</td>
                    <td>{{this.questions}}</td>
                    <td>{{this.responses}}</td>
                    <td>
                        {{#if (eq this.status 'active')}}
                            <span class="badge bg-success-subtle text-success border border-success rounded-pill text-capitalize">Activo</span>
                        {{else}}
                            <span class="badge bg-warning-subtle text-warning-dark border border-warning rounded-pill text-capitalize">Borrador</span>
                        {{/if}}
                    </td>
                    <td class="font-monospace fw-bold">{{this.code}}</td>
                    <td class="pe-4 text-end">
                        {{> quiz-actions this}}
                    </td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="7" class="text-center py-5 text-muted">
                        <i class="bi bi-folder-x h1 d-block mb-3"></i>
                        Aún no has creado ningún cuestionario.
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>