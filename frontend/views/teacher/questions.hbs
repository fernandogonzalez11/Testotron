<main
  id="main-content"
  class="container-fluid py-4"
  role="main"
>
  <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <header>
      <h1 class="h3 fw-bold mb-1">
        {{pageTitle}}
      </h1>

      <p class="text-muted mb-0">
        {{pageDescription}}
      </p>
    </header>

    <a
      href="#"
      class="btn text-white"
      style="background-color: var(--color-primary);"
      data-bs-toggle="modal"
      data-bs-target="#questionModal"
      data-context="question-bank"
    >
      <i class="bi bi-plus-lg me-1"></i> Nueva pregunta
    </a>

  </div>

  <section
    class="card border-0 shadow-sm mb-4"
    aria-label="Búsqueda de preguntas"
  >
    <div class="card-body">
      <form
        action="/teacher/question-bank"
        method="GET"
      >
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0">
            <i class="bi bi-search" aria-hidden="true"></i>
          </span>

          <input
            type="search"
            name="search"
            class="form-control border-start-0"
            placeholder="Buscar preguntas..."
            value="{{filters.search}}"
            aria-label="Buscar preguntas"
          >
        </div>
      </form>
    </div>
  </section>

  <section
    class="row g-4 mb-4"
    aria-label="Estadísticas del banco de preguntas"
  >
    <div class="col-12 col-md-6">
      <article class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">
            Total de preguntas
          </p>

          <p class="h3 fw-bold mb-0">
            {{stats.totalQuestions}}
          </p>
        </div>
      </article>
    </div>

    <div class="col-12 col-md-6">
      <article class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">
            Más utilizadas
          </p>

          <p
            class="h3 fw-bold mb-0"
            style="color: var(--color-success);"
          >
            {{stats.mostUsed}}
          </p>
        </div>
      </article>
    </div>
  </section>

  <section
    class="card border-0 shadow-sm"
    aria-labelledby="questions-table-title"
  >
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <caption
            id="questions-table-title"
            class="visually-hidden"
          >
            Listado de preguntas registradas
          </caption>

          <thead class="table-light">
            <tr>
              <th scope="col">
                Pregunta
              </th>

              <th scope="col">
                Tipo
              </th>

              <th scope="col">
                Dificultad
              </th>

              <th scope="col">
                Usos
              </th>

              <th scope="col">
                Acciones
              </th>
            </tr>
          </thead>

          <tbody>
            {{#if questions.length}}
              {{#each questions}}
                {{> question-bank-row}}
              {{/each}}
            {{else}}
              <tr>
                <td
                  colspan="5"
                  class="text-center py-4 text-muted"
                >
                  No hay preguntas registradas.
                </td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {{> question-modal }}

</main>

<script>

document.addEventListener(
  'question:saved',
  async function(event) {

    /*
    =====================================
    ONLY BANK QUESTIONS
    =====================================
    */

    const saveToBank =
      document.getElementById(
        'saveToBank'
      );

    if (!saveToBank?.checked) {
      return;
    }

    /*
    =====================================
    GET NEW QUESTION
    =====================================
    */

    const q =
      event.detail;

    /*
    =====================================
    REMOVE EMPTY MESSAGE
    =====================================
    */

    const emptyRow =
      document.querySelector(
        'td[colspan="5"]'
      );

    if (emptyRow) {

      emptyRow
        .closest('tr')
        .remove();
    }

    /*
    =====================================
    CREATE ROW
    =====================================
    */

    const tbody =
      document.querySelector(
        'tbody'
      );

    const tr =
      document.createElement('tr');

    tr.setAttribute(
      'data-question-id',
      q.question_id
    );

    tr.innerHTML = `
      <td>
        <strong>
          ${q.question}
        </strong>
      </td>

      <td>
        ${q.type}
      </td>

      <td>
        ${q.difficulty || 'medium'}
      </td>

      <td>
        0
      </td>

      <td>

        <div class="btn-group">

          <button
            class="btn btn-sm btn-outline-primary"
            onclick="editQuestion(${q.question_id})"
          >
            <i class="bi bi-pencil"></i>
          </button>

          <button
            class="btn btn-sm btn-outline-danger"
            onclick="deleteQuestion(${q.question_id})"
          >
            <i class="bi bi-trash"></i>
          </button>

        </div>

      </td>
    `;

    /*
    =====================================
    INSERT FIRST
    =====================================
    */

    tbody.prepend(tr);

  }
);

/*
=====================================
REMOVE QUESTION FROM DOM
=====================================
*/

document.addEventListener(
  'question:deleted',
  function(event) {

    const id =
      event.detail.id;

    const row =
      document.querySelector(
        `[data-question-id="${id}"]`
      );

    if (row) {
      row.remove();
    }

  }
);

</script>

<script src="/assets/js/question-modal.js"></script>
