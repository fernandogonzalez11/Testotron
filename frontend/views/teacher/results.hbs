<main id="main-content" class="container-fluid py-4" role="main">
  <header class="mb-4 d-flex justify-content-between align-items-center">
    <div>
      <h1 class="h3 fw-bold">{{pageTitle}}</h1>
      <p class="text-muted">{{pageDescription}}</p>
    </div>
    <button class="btn btn-success text-white">
      <i class="bi bi-download me-1"></i> Exportar resultados
    </button>
  </header>

  <!-- Filtros -->
  <section class="card border-0 shadow-sm mb-4" aria-label="Filtros de resultados">
    <div class="card-body">
      <form class="row g-3 align-items-center">
        <div class="col-md-3">
          <select class="form-select" name="group">

		  <option value="">
    Todos los grupos
</option>

{{#each groups}}
<option
    value="{{code}}"
    {{#ifEquals ../filters.group code}}
        selected
    {{/ifEquals}}
>
    {{name}}
</option>
{{/each}}

	  </select>
        </div>
        <div class="col-md-3">
          <select class="form-select" name="status">
	  <option value="">
    Todos los estados
</option>

<option
    value="Aprobado"
>
    Aprobado
</option>

<option
    value="Reprobado"
>
    Reprobado
</option>
	  </select>
        </div>
        <div class="col-md-4">
          <input type="search" class="form-control" name="search" placeholder="Buscar estudiante o cuestionario..." value="{{filters.search}}">
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100">Filtrar</button>
        </div>
      </form>
    </div>
  </section>

  <!-- Estadísticas -->
  <section class="row g-4 mb-4" aria-label="Resumen de resultados">
    <div class="col-12 col-md-3">
      <article class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">Total de resultados</p>
          <p class="h3 fw-bold mb-0">{{stats.totalResults}}</p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-3">
      <article class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">Promedio general</p>
          <p class="h3 fw-bold mb-0">{{stats.averageScore}}%</p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-3">
      <article class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">Tasa de aprobación</p>
          <p class="h3 fw-bold mb-0">{{stats.approvalRate}}%</p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-3">
      <article class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <p class="text-muted small mb-2">Intentos totales</p>
          <p class="h3 fw-bold mb-0">{{stats.totalAttempts}}</p>
        </div>
      </article>
    </div>
  </section>

  <!-- Tabla de resultados -->
  <section class="card border-0 shadow-sm" aria-label="Tabla de resultados">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Estudiante</th>
              <th>Cuestionario</th>
              <th>Grupo</th>
              <th>Puntuación</th>
              <th>Estado</th>
              <th>Fecha</th>
              <th>Tiempo</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#if results.length}}
              {{#each results}}
                <tr>
                  <td>{{student}}</td>
                  <td>{{quiz}}</td>
                  <td>{{group}}</td>
                  <td>{{score}}</td>
                  <td>
                    {{#ifEquals status "Aprobado"}}
                      <span class="badge bg-success">{{status}}</span>
                    {{else}}
                      <span class="badge bg-danger">{{status}}</span>
                    {{/ifEquals}}
                  </td>
                  <td>{{date}}</td>
                  <td>{{time}}</td>
		  <td>
			  <a
    href="/results/answer/{{answer_id}}"
    class="btn btn-sm btn-outline-secondary"
>
    <i class="bi bi-eye"></i>
</a>
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr>
                <td colspan="8" class="text-center py-4 text-muted">No hay resultados registrados.</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>
