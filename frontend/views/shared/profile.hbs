<main
  id="main-content"
  class="container-fluid"
  role="main"
>
  <header class="mb-4">
    <h1 class="h3 fw-bold mb-1">
      {{page.title}}
    </h1>

    <p class="text-muted mb-0">
      {{page.subtitle}}
    </p>
  </header>

  <div class="row g-4">
    <div class="col-12 col-lg-4">
      <div class="d-flex flex-column gap-4">
        {{> profile-summary-card user=user}}

        <section
          class="card border-0 shadow-sm"
          aria-labelledby="biography-title"
        >
          <div class="card-body">
            <h2
              id="biography-title"
              class="h5 fw-semibold mb-3"
            >
              Biografía
            </h2>

            <p class="text-muted small mb-0">
              {{user.bio}}
            </p>
          </div>
        </section>
      </div>
    </div>

    <div class="col-12 col-lg-8">
      <section
        class="card border-0 shadow-sm"
        aria-labelledby="account-settings-title"
      >
        <div class="card-body">
          <h2
            id="account-settings-title"
            class="h5 fw-semibold mb-4"
          >
            Configuración de cuenta
          </h2>

          <form action="/profile/update" method="POST">
            <div class="mb-3">
              <label
                for="fullName"
                class="form-label"
              >
                Nombre completo
              </label>

              <input
                id="fullName"
                name="fullName"
                type="text"
                class="form-control"
                value="{{user.name}}"
                required
              >
            </div>

            <div class="mb-3">
              <label
                for="email"
                class="form-label"
              >
                Correo electrónico
              </label>

              <input
                id="email"
                name="email"
                type="email"
                class="form-control"
                value="{{user.email}}"
                required
              >
            </div>

            <div class="mb-4">
              <label
                for="bio"
                class="form-label"
              >
                Biografía
              </label>

              <textarea
                id="bio"
                name="bio"
                rows="4"
                class="form-control"
              >{{user.bio}}</textarea>
            </div>

            <button
              type="submit"
              class="btn text-white"
              style="background-color: var(--color-primary);"
            >
              Guardar cambios
            </button>
          </form>
        </div>
      </section>
    </div>
  </div>
</main>