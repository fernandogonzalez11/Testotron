{{> auth-header}}

<section class="card shadow-sm border-0 p-4 mb-4" aria-labelledby="register-title">
    <h2 id="register-title" class="h4 mb-4 fw-semibold text-sentence">{{pageTitle}}</h2>

    <form action="{{authAction}}" method="POST">
        <!-- Nombre completo -->
        <div class="mb-3">
            <label for="name" class="form-label text-sentence">Nombre completo</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-person text-muted" aria-hidden="true"></i>
                </span>
                <input type="text" id="name" name="name" class="form-control border-start-0" 
                       placeholder="{{placeholders.name}}" required autocomplete="name">
            </div>
        </div>

        <!-- Correo electrónico -->
        <div class="mb-3">
            <label for="email" class="form-label text-sentence">Correo electrónico</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-envelope text-muted" aria-hidden="true"></i>
                </span>
                <input type="email" id="email" name="email" class="form-control border-start-0" 
                       placeholder="{{placeholders.email}}" required autocomplete="email">
            </div>
        </div>

        <!-- Contraseña -->
        <div class="mb-3">
            <label for="password" class="form-label text-sentence">Contraseña</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-lock text-muted" aria-hidden="true"></i>
                </span>
                <input type="password" id="password" name="password" class="form-control border-start-0" 
                       placeholder="{{placeholders.password}}" required autocomplete="new-password">
            </div>
        </div>

        <!-- Rol -->
        <div class="mb-4">
            <label for="role" class="form-label text-sentence">Rol</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-briefcase text-muted" aria-hidden="true"></i>
                </span>
                <select id="role" name="role" class="form-select border-start-0" required>
                    <option value="" disabled selected class="text-sentence">Selecciona un rol</option>
                    {{#each roles}}
                        <option value="{{this.value}}" class="text-sentence">{{this.label}}</option>
                    {{/each}}
                </select>
            </div>
        </div>

        <button type="submit" class="btn btn-primary w-100 py-2 mb-3 text-sentence" aria-label="Crear nueva cuenta">
            Registrarse
        </button>

        <div class="text-center">
            <a href="{{loginUrl}}" class="text-decoration-none" style="color: var(--color-primary);">
                ¿Ya tienes cuenta? Iniciar sesión
            </a>
        </div>
    </form>
</section>