<main class="container py-4">
  <header class="mb-4">
    <h1 class="h3">{{quizTitle}}</h1>
    <p class="text-muted">Resultados del cuestionario</p>
  </header>

  <section>
    <div id="resultBox">{{> result-box}}</div>
  </section>
  
  <section>
    <h2 class="h5 mb-3">Estadísticas del grupo</h2>
    <div id="groupStats">{{> group-stats groupStats}}</div>
  </section>

  <section>
    <h2 class="h5 mb-3">Revisión de respuestas</h2>
    <div id="answersList" class="list-group overflow-auto" style="max-height: 300px;" role="region" aria-label="Revisión de respuestas">
      {{#each answers}}
        {{> answer-item}}
      {{/each}}
    </div>
  </section>
<script src="/assets/js/results-page.js" defer></script>
</main>
