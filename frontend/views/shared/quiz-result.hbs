<main class="container py-4">
  <header class="mb-4">
    <h1 class="h3">{{quizTitle}}</h1>
    <p class="text-muted">Resultados del cuestionario</p>
  </header>

  <section>
    {{> result-box}}
  </section>
  
  <section>
    <h2 class="h5 mb-3">Estadísticas del grupo</h2>
    {{> group-stats groupStats}}
  </section>

  <section>
    <h2 class="h5 mb-3">Revisión de respuestas</h2>
    <div class="list-group overflow-auto" style="max-height: 300px;" role="region" aria-label="Revisión de respuestas">
      {{#each answers}}
        {{> answer-item}}
      {{/each}}
    </div>
  </section>
</main>
