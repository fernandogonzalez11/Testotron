{{!-- frontend/views/shared/dashboard.hbs --}}

<section class="container my-4">
  <!-- HEADER -->
  <div class="d-flex align-items-start justify-content-between mb-4">
    <div>
      <h1 class="h3 mb-1">Panel de control</h1>
      <p class="text-muted small mb-0">Resumen general de tu actividad en Testotron</p>
    </div>

    <div class="d-flex gap-2">
      {{#ifEquals role "teacher"}}
        <a href="/teacher/quizzes/create" class="btn btn-primary">+ Nuevo cuestionario</a>
        <a href="/groups" class="btn btn-outline-secondary">+ Nuevo grupo</a>
      {{/ifEquals}}

      {{#ifEquals role "admin"}}
        <a href="/admin/tables" class="btn btn-primary">Administración</a>
      {{/ifEquals}}

      {{#ifEquals role "student"}}
        <a href="/student/quizzes" class="btn btn-primary">Ver cuestionarios</a>
      {{/ifEquals}}
    </div>
  </div>

  <!-- STATS CARDS -->
  <div class="row g-3 mb-4">
    {{#if stats}}
      <div class="col-6 col-md-3">
        <article class="card shadow-sm border-0">
          <div class="card-body d-flex align-items-center">
            <div class="me-3 p-3 bg-light rounded-circle">
              <i class="bi bi-list-task fs-4"></i>
            </div>
            <div>
              <h3 class="h5 mb-0">
                {{#ifEquals role "student"}}
                  {{stats.quizzes_assigned}}
                {{else}}
                  {{stats.quizzes}}
                {{/ifEquals}}
              </h3>
              <small class="text-muted">
                {{#ifEquals role "student"}}Cuestionarios asignados{{else}}Cuestionarios activos{{/ifEquals}}
              </small>
            </div>
          </div>
        </article>
      </div>

      <div class="col-6 col-md-3">
        <article class="card shadow-sm border-0">
          <div class="card-body d-flex align-items-center">
            <div class="me-3 p-3 bg-light rounded-circle">
              <i class="bi bi-people fs-4"></i>
            </div>
            <div>
              <h3 class="h5 mb-0">{{stats.groups}}</h3>
              <small class="text-muted">{{#ifEquals role "student"}}Grupos activos{{else}}Grupos creados{{/ifEquals}}</small>
            </div>
          </div>
        </article>
      </div>

      <div class="col-6 col-md-3">
        <article class="card shadow-sm border-0">
          <div class="card-body d-flex align-items-center">
            <div class="me-3 p-3 bg-light rounded-circle">
              <i class="bi bi-pencil-square fs-4"></i>
            </div>
            <div>
              <h3 class="h5 mb-0">{{stats.attempts}}</h3>
              <small class="text-muted">{{#ifEquals role "student"}}Intentos realizados{{else}}Respuestas totales{{/ifEquals}}</small>
            </div>
          </div>
        </article>
      </div>

      <div class="col-6 col-md-3">
        <article class="card shadow-sm border-0">
          <div class="card-body d-flex align-items-center">
            <div class="me-3 p-3 bg-light rounded-circle">
              <i class="bi bi-bar-chart-line fs-4"></i>
            </div>
            <div>
              <h3 class="h5 mb-0">
                {{#ifEquals role "student"}}
                  {{stats.average}}
                {{else}}
                  {{stats.students}}
                {{/ifEquals}}
              </h3>
              <small class="text-muted">{{#ifEquals role "student"}}Promedio general{{else}}Estudiantes alcanzados{{/ifEquals}}</small>
            </div>
          </div>
        </article>
      </div>
    {{else}}
      <div class="col-12">
        <div class="card border-0 shadow-sm p-3">No hay estadísticas disponibles</div>
      </div>
    {{/if}}
  </div>

  <div class="row">
    <!-- LEFT COLUMN -->
    <div class="col-12 col-lg-8">

      <!-- WEEKLY ACTIVITY -->
      <section class="card mb-3 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h6 mb-0">Actividad semanal</h2>
            <small class="text-muted">Últimos 7 días</small>
          </div>

          {{#if weeklyActivity}}
            <div class="d-flex align-items-end gap-2" style="height:120px;">
              {{!-- compute bars --}}
              {{#each weeklyActivity}}
                <div class="text-center flex-fill">
                  <div class="mx-auto bg-primary rounded" style="width:24px; height:{{this}}px; max-height:120px;"></div>
                  <small class="d-block text-muted mt-2">{{../weeklyActivityLabels.[@index]}}</small>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="text-muted">Sin actividad registrada</p>
          {{/if}}
        </div>
      </section>

      <!-- GRADE PROGRESS -->
      <section class="card mb-3 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h6 mb-0">Progreso de calificaciones</h2>
            <small class="text-muted">Últimas semanas</small>
          </div>

          {{#if gradeProgress}}
            <div class="mb-3">
              {{#each gradeProgress}}
                <div class="d-flex align-items-center mb-2">
                  <div class="me-3 small text-muted" style="width:90px">{{../gradeProgressLabels.[@index]}}</div>
                  {{> progress-bar current=this total=100}}
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="text-muted">Sin datos disponibles</p>
          {{/if}}
        </div>
      </section>

      <!-- RECENT QUIZZES -->
      <section class="card mb-3 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h6 mb-0">Cuestionarios recientes</h2>
            <a href="/teacher/quizzes" class="small">Ver todos</a>
          </div>

          {{#if recentQuizzes.length}}
            <div class="row g-3">
              {{#each recentQuizzes}}
                <div class="col-12">
                  <article class="card border-0">
                    <div class="card-body d-flex justify-content-between align-items-center">
                      <div>
                        <h3 class="h6 mb-1">{{title}}</h3>
                        <small class="text-muted">{{group_name}} · {{created_at}}</small>
                      </div>
                      <div class="text-end">
                        <span class="badge bg-secondary mb-2">{{status}}</span>
                        <div class="d-flex gap-2 mt-2">
                          {{#ifEquals ../role "student"}}
                            <a class="btn btn-sm btn-primary" href="#">Resolver</a>
                            <a class="btn btn-sm btn-outline-secondary" href="#">Ver detalles</a>
                          {{else}}
                            <a class="btn btn-sm btn-primary" href="#">Ver resultados</a>
                            <a class="btn btn-sm btn-outline-secondary" href="#">Ver cuestionario</a>
                          {{/ifEquals}}
                        </div>
                      </div>
                    </div>
                  </article>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="text-muted">No hay cuestionarios recientes</p>
          {{/if}}
        </div>
      </section>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="col-12 col-lg-4">
      <!-- NOTIFICATIONS -->
      <section class="card mb-3 shadow-sm">
        <div class="card-body">
          <h2 class="h6 mb-3">Notificaciones</h2>

          {{#if notifications.length}}
            <ul class="list-unstyled mb-0">
              {{#each notifications}}
                <li class="py-2 border-bottom">
                  <div class="small text-muted">{{created_at}}</div>
                  <div>{{#if quiz_title}}<strong>{{quiz_title}}</strong>{{else}}{{message}}{{/if}}</div>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="text-muted mb-0">No hay notificaciones</p>
          {{/if}}
        </div>
      </section>

      {{#ifEquals role "student"}}
        <!-- Completion Rate -->
        <section class="card mb-3 shadow-sm">
          <div class="card-body">
            <h2 class="h6 mb-3">Progreso de finalización</h2>
            {{#if completionRate}}
              <div class="d-flex align-items-center mb-2">
                <div class="fw-bold fs-4 me-3">{{completionRate}}%</div>
                <div class="flex-grow-1">
                  {{> progress-bar current=completionRate total=100}}
                </div>
              </div>
            {{else}}
              <p class="text-muted">Sin datos disponibles</p>
            {{/if}}
          </div>
        </section>

        <!-- Most active groups -->
        <section class="card mb-3 shadow-sm">
          <div class="card-body">
            <h2 class="h6 mb-3">Grupos más activos</h2>
            {{#if activeGroups.length}}
              <ul class="list-unstyled mb-0">
                {{#each activeGroups}}
                  <li class="d-flex justify-content-between py-2 border-bottom">
                    <div>
                      <div class="fw-bold">{{name}}</div>
                      <small class="text-muted">Código: {{code}}</small>
                    </div>
                    <div class="text-end small text-muted">{{attempts_count}} intentos</div>
                  </li>
                {{/each}}
              </ul>
            {{else}}
              <p class="text-muted">No hay grupos activos</p>
            {{/if}}
          </div>
        </section>
      {{/ifEquals}}

      {{#ifEquals role "teacher"}}
        <!-- Top performing quizzes -->
        <section class="card mb-3 shadow-sm">
          <div class="card-body">
            <h2 class="h6 mb-3">Top quizzes</h2>
            {{#if quizPerformance.length}}
              <ul class="list-unstyled mb-0">
                {{#each quizPerformance}}
                  <li class="py-2 border-bottom d-flex justify-content-between align-items-center">
                    <div>
                      <div class="fw-bold small">{{title}}</div>
                      <small class="text-muted">{{group_name}}</small>
                    </div>
                    <div style="width:120px">
                      {{> progress-bar current=avg_score total=100}}
                    </div>
                  </li>
                {{/each}}
              </ul>
            {{else}}
              <p class="text-muted">No hay datos de rendimiento</p>
            {{/if}}
          </div>
        </section>
      {{/ifEquals}}

      {{#ifEquals role "admin"}}
        <!-- Admin quick stats -->
        <section class="card mb-3 shadow-sm">
          <div class="card-body">
            <h2 class="h6 mb-3">Estadísticas</h2>
            <ul class="list-unstyled small mb-0">
              <li class="py-1">Total cuestionarios: <strong>{{stats.quizzes}}</strong></li>
              <li class="py-1">Total usuarios: <strong>{{stats.students}}</strong></li>
              <li class="py-1">Respuestas: <strong>{{stats.attempts}}</strong></li>
            </ul>
          </div>
        </section>
      {{/ifEquals}}

    </div>
  </div>
</section>