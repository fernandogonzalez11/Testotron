{{> auth-header}}

<section class="card shadow-sm border-0 p-4 mb-4" aria-labelledby="login-title">
    <h2 id="login-title" class="h4 mb-4 fw-semibold text-sentence">{{pageTitle}}</h2>

    <form action="{{authAction}}" method="POST">
        {{!-- Sección de Correo electrónico --}}
        <div class="mb-3">
            <label for="email" class="form-label text-sentence">Correo electrónico</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-envelope text-muted" aria-hidden="true"></i>
                </span>
                <input type="email" id="email" name="email" class="form-control border-start-0" 
                    placeholder="{{placeholders.email}}" required autocomplete="email">
            </div>
        </div>

        {{!-- Sección de Contraseña --}}
        <div class="mb-4">
            <label for="password" class="form-label text-sentence">Contraseña</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-lock text-muted" aria-hidden="true"></i>
                </span>
                <input type="password" id="password" name="password" class="form-control border-start-0" 
                    placeholder="{{placeholders.password}}" required autocomplete="current-password">
            </div>
        </div>

        <button type="submit" class="btn btn-primary w-100 py-2 mb-3 text-sentence" aria-label="Enviar credenciales para iniciar sesión">
            {{pageTitle}}
        </button>

        <div class="text-center">
            <a href="{{registerUrl}}" class="text-decoration-none" style="color: var(--color-primary);">
                ¿No tienes cuenta? Regístrate
            </a>
        </div>
    </form>
</section>

{{> quick-access}}