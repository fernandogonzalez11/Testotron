<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{appName}} - {{pageTitle}}</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="icon" type="image/x-icon" href="/assets/img/logo.png">
    
    <!-- CSS Core con Paleta de Colores -->
    <link rel="stylesheet" href="/assets/css/main.css">

    <!-- Secciones opcionales para CSS específico -->
    {{{_sections.head}}}
</head>
<body class="bg-light">

    <!-- Enlace de salto para accesibilidad (Skip to content) -->
    <a href="#main-content" 
        class="visually-hidden-focusable position-absolute top-0 start-0 m-3 btn btn-light shadow-lg" 
        style="z-index: 2000;">
        Saltar al contenido principal
    </a>

    <div class="d-flex flex-column min-vh-100">
        
        <!-- Navbar Superior (Accesibilidad: role="banner") -->
        <header role="banner">
            {{> navbar}}
        </header>

        <div class="d-flex flex-grow-1" style="height: calc(100vh - 70px); overflow: hidden;">
            <!-- Sidebar -->
            <aside class="sidebar-wrapper bg-white border-end" role="navigation">
                {{> sidebar}}
            </aside>

            <!-- Right Column: Main + Footer -->
            <div class="d-flex flex-column flex-grow-1">
                <!-- Main content scrolls independently -->
                <main id="main-content" class="container-fluid p-4 flex-grow-1 overflow-auto" role="main">
                    {{{body}}}
                </main>

                <!-- Footer stays at the bottom of this flex column -->
                <footer class="py-2 border-top bg-white" role="contentinfo">
                    <div class="text-center text-muted small px-4">
                        {{> footer}}
                    </div>
                </footer>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script>window.__API_BASE__ = window.__API_BASE__ || (window.__env && window.__env.API_BASE) || 'http://localhost:8080';</script>
    <script src="/assets/js/env.js"></script>
    <script src="/assets/js/api-client.js"></script>
    <script src="/assets/js/auth.js"></script>
    <script src="/assets/js/hydrate-user.js"></script>
    <script src="/assets/js/logout.js"></script>
    <script src="/assets/js/main.js"></script>
    <script src="/assets/js/quick-access.js"></script>
    <script src="/assets/js/teacher-quizzes.js" defer></script>
    {{{_sections.scripts}}}
</body>
</html>